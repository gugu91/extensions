{
  "name": "@gugu910/pi-slack-api",
  "version": "0.1.0",
  "type": "module",
  "description": "Typed Slack Web API client and CLI generated from Slack's OpenAPI spec",
  "author": "Will Porcellini <5994936+gugu91@users.noreply.github.com>",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gugu91/extensions.git",
    "directory": "slack-api"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/generated/index.js",
  "exports": {
    ".": "./dist/generated/index.js",
    "./cli": "./dist/cli.js",
    "./generated": "./dist/generated/index.js",
    "./generated/*": "./dist/generated/*",
    "./package.json": "./package.json"
  },
  "files": [
    "README.md",
    "bin/",
    "dist/",
    "scripts/generate.ts"
  ],
  "keywords": [
    "pi-package"
  ],
  "pi": {},
  "bin": {
    "slack-api": "./bin/slack-api"
  },
  "scripts": {
    "build": "node ../scripts/build-package.mjs",
    "prepack": "pnpm run build",
    "generate": "node --experimental-strip-types scripts/generate.ts",
    "lint": "eslint . --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@hey-api/openapi-ts": "^0.95.0",
    "yaml": "^2.8.1"
  }
}
