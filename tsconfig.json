{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "types": ["node"],
    "verbatimModuleSyntax": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "nvim-bridge/**/*.ts",
    "neon-psql/**/*.ts",
    "slack-api/**/*.ts",
    "slack-bridge/**/*.ts",
    "types/**/*.d.ts",
    "vitest.config.ts"
  ]
}
