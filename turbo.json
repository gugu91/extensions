{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "lint": {
      "inputs": ["**/*.ts", "eslint.config.mjs"],
      "outputs": []
    },
    "typecheck": {
      "inputs": ["**/*.ts", "tsconfig.json", "../types/**/*.d.ts"],
      "outputs": []
    },
    "test": {
      "inputs": ["**/*.ts", "**/*.test.ts", "vitest.config.ts"],
      "outputs": [],
      "passThroughEnv": ["TMPDIR"]
    }
  }
}
